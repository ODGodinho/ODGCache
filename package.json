{
    "name": "@odg/cache",
    "version": "0.0.0",
    "description": "Stanley TheTemplate for typescript project",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "homepage": "https://github.com/ODGodinho/Stanley-TheTemplate-Typescript",
    "exports": {
        ".": "./dist/index.js",
        "./KeyvCacheHandler": "./dist/Cache/Handlers/KeyvCacheHandler.js"
    },
    "scripts": {
        "build": "rimraf dist/ && tsc --project ./tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "build:watch": "npm run build && (concurrently \"tsc --project ./tsconfig.build.json -w\" \"tsc-alias -p tsconfig.build.json -w\")",
        "dev": "tsx --env-file=.env ./src/index.ts",
        "start": "node --env-file=.env ./dist/index.js",
        "start:build": "yarn build && node --env-file=.env ./dist/index.js",
        "lint": "odg-lint",
        "lint:fix": "odg-lint --fix",
        "prepare": "husky",
        "test": "vitest run",
        "test:ci": "vitest run --passWithNoTests",
        "test:watch": "vitest --watch"
    },
    "publishConfig": {
        "access": "public"
    },
    "lint-staged": {
        "*": [ "npm run lint:fix" ]
    },
    "release": {
        "branches": [
            "+([0-9])?(.{+([0-9]),x}).x",
            "main",
            "master",
            "next",
            "next-major",
            {
                "name": "beta",
                "prerelease": true
            },
            {
                "name": "alpha",
                "prerelease": true
            }
        ],
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/npm",
            "@semantic-release/github"
        ]
    },
    "files": [
        "./dist/",
        "./README.md"
    ],
    "author": "Dragons Gamers <https://www.linkedin.com/in/victor-alves-odgodinho>",
    "license": "MIT",
    "dependencies": {
        "@odg/exception": "^1.8.0"
    },
    "peerDependencies": {
        "keyv": "^5"
    },
    "peerDependenciesMeta": {
        "keyv": {
            "optional": true
        }
    },
    "devDependencies": {
        "@odg/chemical-x": "^2.1.0",
        "@odg/eslint-config": "^3",
        "@odg/tsconfig": "^1.2.1",
        "@types/keyv": "^4.2.0",
        "@types/node": "^25.5.0",
        "@vitest/coverage-istanbul": "^4.1.1",
        "@vitest/runner": "^4.1.1",
        "concurrently": "^9.2.1",
        "husky": "^9.1.7",
        "keyv": "^5.6.0",
        "lint-staged": "^16.4.0",
        "rimraf": "^6.1.3",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.2",
        "vitest": "^4.1.1"
    },
    "packageManager": "yarn@4.13.0"
}
